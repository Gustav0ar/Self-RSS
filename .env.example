# Development environment example only.
# Production must use real infrastructure credentials and unique random secrets.
NODE_ENV=development

# SQLite
DATABASE_URL=data/rss.db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=dev-only-change-me-before-production-32chars
JWT_REFRESH_SECRET=dev-only-change-me-refresh-before-production-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false

# Web
VITE_API_URL=http://localhost:3000

# Admin
# ADMIN_EMAIL=admin@local.test
# ADMIN_PASSWORD=dev-only-admin-password

# Feed sync
FEED_SYNC_CONCURRENCY=5
FEED_SYNC_TIMEOUT_MS=30000
FEED_MAX_CONTENT_LENGTH=5242880
FEED_ALLOW_PRIVATE_HOSTS=false

# Rate Limiting
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_FEED_CREATE_MAX=100
RATE_LIMIT_SEARCH_MAX=100
