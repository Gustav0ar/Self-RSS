{
	"name": "self-feed",
	"private": true,
	"workspaces": [
		"packages/shared",
		"packages/api",
		"packages/web"
	],
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun run --filter '*' test",
		"test:unit": "bun run --filter '*' test:unit",
		"test:integration": "bun scripts/run-api-integration.ts",
		"test:e2e": "bun scripts/run-playwright.ts",
		"test:all": "bun run test && bun run test:integration && bun run test:e2e",
		"db:generate": "bun run --filter '@self-feed/api' db:generate",
		"db:migrate": "bun run --filter '@self-feed/api' db:migrate",
		"db:seed": "bun run --filter '@self-feed/api' db:seed",
		"openapi:generate": "bun run --filter '@self-feed/api' openapi:generate",
		"dev": "bun run dev:prepare && bun run dev:infra && bun run dev:services",
		"dev:api": "API_HOST=0.0.0.0 bun run --filter '@self-feed/api' dev",
		"dev:worker": "bun run --filter '@self-feed/api' dev:worker",
		"dev:web": "bun run --filter '@self-feed/web' dev",
		"dev:services": "bun scripts/dev-services.ts",
		"dev:prepare": "bun scripts/compose.ts stop api worker web || true && (command -v fuser >/dev/null && fuser -k 3000/tcp >/dev/null 2>&1 || true) && (command -v lsof >/dev/null && lsof -tiTCP:3000 -sTCP:LISTEN | xargs -r kill >/dev/null 2>&1 || true)",
		"dev:infra": "bun scripts/compose.ts up -d redis",
		"dev:down": "bun scripts/compose.ts down",
		"seed:review": "bun scripts/seed-local-review.ts",
		"build": "bun run --filter '*' build",
		"android:check": "bash ./scripts/android-check.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"dompurify": "3.4.11",
		"undici": "7.28.0"
	}
}
