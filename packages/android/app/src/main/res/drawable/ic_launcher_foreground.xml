<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground.

    The launcher canvas is 108x108dp; the inner 72x72dp is the "safe zone"
    (any visible content must live inside it). We translate a 72x72dp
    design into the center so the launcher can mask it (circle, squircle,
    teardrop) without clipping the artwork.

    The design mirrors packages/web/public/favicon.svg: a rounded square
    with an indigo->violet gradient and a white RSS glyph. The web version
    uses 64x64 with rx=14, stroke 3.5, and the glyph spans roughly the
    inner-right of the canvas. We rescale that to 72x72 with rx=16 here.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Rounded square, indigo->violet gradient, centered in safe zone. -->
    <path
        android:pathData="M34,18 L74,18 A16,16 0 0 1 90,34 L90,74 A16,16 0 0 1 74,90 L34,90 A16,16 0 0 1 18,74 L18,34 A16,16 0 0 1 34,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF4F46E5" />
                <item android:offset="1.0" android:color="#FF8B5CF6" />
            </gradient>
        </aapt:attr>
    </path>

    <!--
        RSS glyph, white. Coordinates mirror favicon.svg, scaled 72/64
        and translated to fit centered on the square. The web favicon's
        outer arc starts at (20,22) on a 64x64 canvas with a 16-radius
        arc; on 72x72 that becomes (22.5,24.75) with an 18-radius arc.
    -->
    <group
        android:translateX="4.5"
        android:translateY="4.5">
        <path
            android:strokeColor="#FFF8FAFC"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M22.5,24.75 A18,18 0 0 1 40.5,42.75" />
        <path
            android:strokeColor="#FFF8FAFC"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M22.5,33.75 A9,9 0 0 1 31.5,42.75" />
        <path
            android:fillColor="#FFF8FAFC"
            android:pathData="M24.75,42.75 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0" />
    </group>
</vector>
