<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy (non-adaptive) round launcher icon. Vector so the result is
    crisp at any density. The art is the same as ic_launcher.xml; the
    launcher applies its own circular mask, so we don't pre-crop.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M34,18 L74,18 A16,16 0 0 1 90,34 L90,74 A16,16 0 0 1 74,90 L34,90 A16,16 0 0 1 18,74 L18,34 A16,16 0 0 1 34,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF4F46E5" />
                <item android:offset="1.0" android:color="#FF8B5CF6" />
            </gradient>
        </aapt:attr>
    </path>

    <group
        android:translateX="4.5"
        android:translateY="4.5">
        <path
            android:strokeColor="#FFF8FAFC"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M22.5,24.75 A18,18 0 0 1 40.5,42.75" />
        <path
            android:strokeColor="#FFF8FAFC"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M22.5,33.75 A9,9 0 0 1 31.5,42.75" />
        <path
            android:fillColor="#FFF8FAFC"
            android:pathData="M24.75,42.75 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0" />
    </group>
</vector>
