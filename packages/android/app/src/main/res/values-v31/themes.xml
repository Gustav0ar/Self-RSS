<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        API 31+ only. Older devices fall back to the plain
        `values/themes.xml`, which has no splash overrides — the system
        falls back to the default window background.
    -->
    <style name="Theme.SelfFeedAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.SelfFeedAndroid</item>
    </style>
</resources>
