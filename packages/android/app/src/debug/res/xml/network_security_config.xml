<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only override of the production network security config.

    Debug builds let the login screen target emulator, localhost, and LAN-hosted
    development APIs such as 10.0.22.22:3000. Release builds keep the HTTPS-only
    network security config under src/release.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
